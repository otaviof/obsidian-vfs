{
  "name": "obsidian-vfs",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "packageManager": "pnpm@11.0.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "clean": "pnpm -r run clean",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "ci": "pnpm lint && pnpm build && pnpm test",
    "package:vscode": "pnpm --filter obsidian-vfs run package && ls -lhtr packages/vscode/*.vsix",
    "cli": "node packages/cli/dist/main.js",
    "audit": "pnpm audit",
    "check:bundles": "git diff --exit-code packages/claude-plugin/bundle/",
    "check:versions:npm": "hack/check-version.sh packages/core/package.json packages/cli/package.json",
    "check:versions:vscode": "hack/check-version.sh packages/vscode/package.json",
    "check:published:npm": "hack/check-published.sh npm @obsidian-vfs/cli packages/cli/package.json",
    "check:published:vscode": "hack/check-published.sh vscode otaviof.obsidian-vfs packages/vscode/package.json",
    "publish:npm": "pnpm publish:npm:core && pnpm publish:npm:cli",
    "publish:npm:core": "hack/publish-npm.sh packages/core",
    "publish:npm:cli": "hack/publish-npm.sh packages/cli",
    "publish:vscode": "pnpm --filter obsidian-vfs run publish",
    "reset": "pnpm -r run clean && rm -rf node_modules packages/*/node_modules && pnpm install"
  },
  "pnpm": {
    "shamefullyHoist": false,
    "overrides": {
      "fast-uri": ">=3.1.2"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/node": "^25.7.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "jiti": "^2.6.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  }
}
