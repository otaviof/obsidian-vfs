{
  "name": "@obsidian-vfs/cli",
  "version": "0.2.1",
  "type": "module",
  "description": "CLI for Obsidian VFS — provision skills/agents, inspect vault resources",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/otaviof/obsidian-vfs",
    "directory": "packages/cli"
  },
  "keywords": [
    "obsidian",
    "vault",
    "vfs",
    "cli"
  ],
  "bin": {
    "obsidian-vfs": "./dist/main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm exec tsc -b tsconfig.build.json",
    "clean": "pnpm exec tsc -b --clean tsconfig.build.json"
  },
  "dependencies": {
    "@obsidian-vfs/core": "workspace:^",
    "yaml": "^2.9.0"
  }
}
