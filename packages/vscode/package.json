{
  "name": "obsidian-vfs",
  "displayName": "Obsidian VFS",
  "description": "Virtual file system bridging Obsidian vaults into VSCode",
  "version": "0.1.0",
  "private": true,
  "publisher": "obsidian-vfs",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onFileSystem:obs",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "obsidianVFS.mount",
        "title": "Obsidian VFS: Mount Folder"
      },
      {
        "command": "obsidianVFS.unmount",
        "title": "Obsidian VFS: Unmount Folder"
      },
      {
        "command": "obsidianVFS.openInObsidian",
        "title": "Obsidian VFS: Open in Obsidian"
      },
      {
        "command": "obsidianVFS.searchNotes",
        "title": "Obsidian VFS: Search Notes"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "obsidianVFS",
          "name": "Obsidian VFS",
          "when": "obsidianVFS.active"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "obsidianVFS",
        "contents": "No vault folders mounted.\n[Mount Folder](command:obsidianVFS.mount)"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "obsidianVFS.openInObsidian",
          "when": "viewItem == obsFile",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Obsidian VFS",
      "properties": {
        "obsidianVFS.cliPath": {
          "type": "string",
          "default": "obsidian",
          "description": "Path to the Obsidian CLI binary"
        },
        "obsidianVFS.timeoutMs": {
          "type": "number",
          "default": 10000,
          "description": "CLI operation timeout in milliseconds"
        },
        "obsidianVFS.treeViewTitle": {
          "type": "string",
          "default": "",
          "description": "Custom title for the Explorer tree view (defaults to \"Obsidian: <vault_name>\")"
        },
        "obsidianVFS.autoMount": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Vault-relative folders to display in the Explorer tree view"
        }
      }
    }
  },
  "capabilities": {
    "virtualWorkspaces": true
  },
  "scripts": {
    "build": "tsc --noEmit && node esbuild.mjs",
    "package": "vsce package --no-dependencies --allow-missing-repository -o obsidian-vfs.vsix",
    "clean": "rm -rf dist *.vsix"
  },
  "dependencies": {
    "@obsidian-vfs/core": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "^1.100.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.0"
  }
}
