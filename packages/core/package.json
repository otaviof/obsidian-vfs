{
  "name": "@obsidian-vfs/core",
  "version": "0.3.1",
  "type": "module",
  "description": "Core library for Obsidian VFS — vault resolution, content processing, path security",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/otaviof/obsidian-vfs",
    "directory": "packages/core"
  },
  "keywords": [
    "obsidian",
    "vault",
    "vfs"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/test-helpers.d.ts",
      "import": "./dist/test-helpers.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm exec tsc -b tsconfig.build.json",
    "clean": "pnpm exec tsc -b --clean tsconfig.build.json"
  },
  "devDependencies": {
    "vitest": "^4.1.6"
  }
}
